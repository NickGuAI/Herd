{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/apps/herd/Dockerfile",
    "watchPatterns": [
      "/apps/herd/**",
      "/packages/ai-services/**",
      "/packages/auth-providers/**",
      "/packages/herd-cli/**",
      "/packages/sse-streaming/**",
      "/packages/telemetry/**",
      "/packages/tsconfig/**",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml"
    ]
  },
  "deploy": {
    "startCommand": "node dist-server/server/index.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "requiredMountPath": "/data/.herd",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
